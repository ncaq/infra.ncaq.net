#!/usr/bin/env bash
set -euo pipefail

# 存在していれば開発時に使う共有されている環境変数群を読み込みます。
dotenv_if_exists .env.deve

# Nix Flakesのロード。
use flake . --accept-flake-config

# sopsで暗号化されたシークレットを復号して読み込みます。
if sops_output="$(sops --input-type dotenv --output-type dotenv -d .env.sops)"; then
  # dotenvはプロセス置換に対応していないため、一時ファイルに書き出してから読み込みます。
  sops_output_file=$(mktemp)
  echo "$sops_output" >"$sops_output_file"
  dotenv "$sops_output_file"
  # trapを使うとdirenvの内部機構を壊してしまうので普通に削除します。
  # 途中でエラーになった時に平文ファイルが残ってしまう問題はありますが、
  # mktempで確保したファイルはそのうちOSによるクリーンアップで消えますし、
  # どうせ成功しても環境変数にシークレットは平文で展開されているので、
  # 許容できるリスクと判断しています。
  rm -f "$sops_output_file"
else
  log_error ".env.sopsの復号に失敗しました。"
fi

# 存在していればローカルなカスタムが最後に優先されるように読み込みます。
dotenv_if_exists .env.local
